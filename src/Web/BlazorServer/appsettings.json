{
  "Environment": "UAT",
  "DbProvider": "MSSQL", // InMemory|PostgreSQL|MSSQL|Sqlite
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=SeedDb;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
    //"DefaultConnection": "Host=(localdb);Port=5432;Database=SeedDb;Username=admin;Password=P@ssword",
    //"DefaultConnection": "Data Source=D:\\Files\\Sqlite\\Seed.Db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Hangfire": "Warning",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Hangfire": "Warning",
        "Microsoft": "Error",
        "System": "Information",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "FileAsync"
      }
    ]
  },
  "RequestLogging": {
    "Enable": true,
    "IncludeRequest": false,
    "IncludeResponse": false,
    "ExcludePaths": [ "hc" ]
  },
  "MemberOfDomain": null
}
